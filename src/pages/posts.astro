      width: 88%;
    }
    .side-bar-option-header {
      height: 25px;
      display: flex;
      align-items: center;
      padding: 0 5px;
      background: linear-gradient(to right, rgb(255, 255, 255) 0%, rgb(200, 211, 244) 100%);
      border-radius: 5px 5px 0 0;
    }
    .side-bar-option-options {
      padding: 8px;
      display: flex;
      flex-direction: column;
      background-color: rgb(227, 235, 252);
      border: 1px solid white; 
      border-top: none;
    }
    .side-bar-option-option {
      display: flex;
      flex-direction: row;
      gap: 5px;
      align-items: center;
      padding: 0 4px;
      height: 25px;
      border-radius: 5px;
    }

    @media screen and (max-width: 576px) {
      .side-bar-options {
        display: none;
      }
      .file-explorer-window {
        flex-direction: column;
      }
      .window {
        width: 95%;
        height: 90dvh;
      }
    }
</style>